@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  /* Colors - Aegean Serenity */
  --color-warm-white: #FAFAF8;
  --color-sand: #E8DCC4;
  --color-aegean-blue: #17324a;
  --color-deep-med: #2C5F8D;
  --color-accent-gold: #C9A961;
  --color-charcoal: #2F3437;
  --color-white: #FFFFFF;
  --color-success: #5F9B7C;
  --color-error: #D47B6A;

  /* Map Category Colors */
  --color-map-beach: #D7BAD5;
  --color-map-rental: #C9A961;
  --color-map-dining: #A86869;
  --color-map-supermarket: #7DAC8F;
  --color-map-pharmacy: #7394AC;
  --color-map-transport: #837DA4;

  /* Spacing (Fluid) */
  --space-xs: clamp(0.25rem, 0.5vw, 0.5rem);
  --space-sm: clamp(0.75rem, 1.5vw, 1rem);
  --space-md: clamp(1rem, 2vw, 1.5rem);
  --space-lg: clamp(1.5rem, 3vw, 2.5rem);
  /* The Luxury Margin */
  --space-xl: clamp(2rem, 5vw, 4rem);

  /* Typography (Fluid) */
  --font-h1: clamp(2rem, 5vw, 3.5rem);
  --font-h2: clamp(1.5rem, 3.5vw, 2.25rem);
  --font-body: clamp(0.9375rem, 1.5vw, 1rem);

  /* Radius */
  --radius-subtle: 4px;

  /* Shadows */
  --shadow-sm: 0 1px 2px rgba(47, 52, 55, 0.06);
  --shadow-md: 0 2px 8px rgba(47, 52, 55, 0.08);
  --shadow-lg: 0 4px 16px rgba(47, 52, 55, 0.10);
  --shadow-hover: 0 6px 20px rgba(74, 144, 226, 0.12);

  /* Animation */
  --ease-premium: cubic-bezier(0.4, 0, 0.2, 1);

  /* Defaults */
  --background: var(--color-warm-white);
  --foreground: var(--color-charcoal);

  --header-height: 80px;
  --container-max: 1280px;

  /* Calendar Theme Variables (Light Theme Defaults) */
  --cal-nav-color: var(--color-aegean-blue);
  --cal-label-color: var(--color-charcoal);
}

html {
  scroll-behavior: smooth;
}

body {
  color: var(--foreground);
  background: var(--background);
  font-family: var(--font-inter), sans-serif;
  overflow-x: hidden;
  /* Prevent horizontal scroll from animations */
}

h1,
h2,
h3,
h4,
h5,
h6 {
  font-family: var(--font-montserrat), sans-serif;
  color: var(--color-charcoal);
  text-transform: uppercase;
  letter-spacing: 0.15em;
}

/* Base Styles for Maps */
.map-tiles-brand {
  filter: hue-rotate(10deg);
}

.leaflet-popup-content-wrapper {
  border-radius: var(--radius-subtle) !important;
  box-shadow: var(--shadow-md) !important;
}

.leaflet-popup-content {
  margin: 12px !important;
  font-family: var(--font-inter) !important;
}

/* =========================================
   Global Calendar Standardization (react-day-picker)
   ========================================= */

/* Base Styles (moved from Calendar.tsx inline) */
.rdp .rdp-head_cell {
  color: var(--color-charcoal);
  opacity: 0.6;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
}

.rdp .rdp-day {
  transition: background-color 0.2s;
  font-family: var(--font-inter);
}

/* Base Overrides for Shape & Text */
.rdp-selected:not(.rdp-day_outside) {
  border-radius: var(--radius-subtle);
}

.rdp-range_start:not(.rdp-day_outside) {
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
  border-top-left-radius: var(--radius-subtle);
  border-bottom-left-radius: var(--radius-subtle);
}

.rdp-range_end:not(.rdp-day_outside) {
  border-top-left-radius: 0;
  border-bottom-left-radius: 0;
  border-top-right-radius: var(--radius-subtle);
  border-bottom-right-radius: var(--radius-subtle);
}

.rdp-range_middle:not(.rdp-day_outside) {
  border-radius: 0;
  font-weight: 500;
}

/* --- LIGHT THEME (Default/BookingCard) --- */
.calendar-light .rdp .rdp-selected:not(.rdp-day_outside),
.calendar-light .rdp .rdp-range_start:not(.rdp-day_outside),
.calendar-light .rdp .rdp-range_end:not(.rdp-day_outside) {
  background-color: var(--color-aegean-blue);
  color: white;
}

/* Fix for layering: Transparentize internal button */
.calendar-light .rdp .rdp-selected .rdp-button_reset,
.calendar-light .rdp .rdp-selected .rdp-day_content {
  background-color: transparent;
  color: white;
  border-radius: inherit;
}

.calendar-light .rdp .rdp-range_middle:not(.rdp-day_outside) {
  background-color: rgba(0, 0, 0, 0.06);
  color: var(--color-charcoal);
}

.calendar-light .rdp .rdp-today:not(.rdp-day_outside) {
  color: var(--color-aegean-blue);
  font-weight: 800;
}

/* --- DARK THEME (FilterPanel) --- */
.calendar-dark .rdp-root {
  --rdp-accent-color: var(--color-accent-gold);
  --rdp-accent-background-color: rgba(44, 95, 141, 0.3);
  --rdp-range_start-date-background-color: var(--color-accent-gold);
  --rdp-range_end-date-background-color: var(--color-accent-gold);
  --rdp-range_middle-background-color: rgba(44, 95, 141, 0.3);
  --rdp-range_start-color: white;
  --rdp-range_end-color: white;
  --rdp-range_middle-color: white;
  --rdp-today-color: var(--color-accent-gold);
}

/* Fix for layering: Transparentize internal button */
.calendar-dark .rdp .rdp-selected .rdp-button_reset,
.calendar-dark .rdp .rdp-selected .rdp-day_content {
  background-color: transparent;
  color: white;
  border-radius: inherit;
}

.calendar-dark .rdp .rdp-range_middle:not(.rdp-day_outside) {
  background-color: rgba(44, 95, 141, 0.3);
  /* Subtle Blue */
  color: white;
}

.calendar-dark .rdp .rdp-today:not(.rdp-day_outside) {
  color: var(--color-accent-gold);
  font-weight: 800;
}

.calendar-dark .rdp .rdp-head_cell {
  color: rgba(255, 255, 255, 0.6);
}

.calendar-dark .rdp .rdp-caption_label {
  color: white;
}

/* Dark Theme Variable Overrides */
.calendar-dark {
  --cal-nav-color: white;
  --cal-label-color: white;
}

/* 2. Blocked Date Masking (The "Booked" Look) */
.rdp-day_booked,
.rdp-day_maintenance,
.rdp-day_renovation,
.rdp-day_season,
.rdp-day_other {
  position: relative;
  color: transparent !important;
  /* Hide the number */
  background-color: rgba(0, 0, 0, 0.05);
  /* Subtle default background */
  pointer-events: none;
}

.rdp-day_booked {
  background-color: rgba(220, 38, 38, 0.1) !important;
}

/* Red-100 equivalent */
.rdp-day_maintenance {
  background-color: rgba(234, 88, 12, 0.1) !important;
}

/* Orange-100 */
.rdp-day_renovation {
  background-color: rgba(217, 119, 6, 0.1) !important;
}

/* Amber-100 */

/* The Centered Label */
.rdp-day_booked::after,
.rdp-day_maintenance::after,
.rdp-day_renovation::after,
.rdp-day_season::after,
.rdp-day_other::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 0.6rem;
  font-weight: 900;
  text-transform: uppercase;
  color: var(--color-charcoal);
  opacity: 0.7;
  letter-spacing: 0.05em;
}

.rdp-day_booked::after {
  content: 'BOOKED';
  color: #7f1d1d;
}

/* Red-900 */
.rdp-day_maintenance::after {
  content: 'MAINT';
  color: #7c2d12;
}

.rdp-day_renovation::after {
  content: 'RENO';
  color: #78350f;
}

.rdp-day_season::after {
  content: 'CLOSED';
}

.rdp-day_other::after {
  content: 'BLOCK';
}
